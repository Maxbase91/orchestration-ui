# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example (this file) is committed.

# ── Browser-exposed (Vite will embed these in the client bundle) ──
# Safe to expose per Supabase's anon-key design — RLS on the Supabase side is
# the real security boundary. Until auth is wired up, policies are "allow all",
# meaning anyone with the URL can read/write every table. Do not put production
# data in a project with open policies.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# ── Server-side (Vercel serverless functions under api/) ──
# Same URL as above, kept separate so the server code doesn't depend on VITE_ prefix.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Service-role key — bypasses RLS. Only used by api/admin/seed.ts for the
# one-time import. NEVER expose this with a VITE_ prefix, never commit it.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# Shared secret for the admin seed endpoint. Pass as `x-admin-secret` header.
ADMIN_SEED_SECRET=change-me-to-a-random-string

# ── LLM (optional; used by api/ai.ts and api/chat-intake.ts) ──
OPENAI_API_KEY=
